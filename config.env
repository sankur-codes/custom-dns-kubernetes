# config.env — Central configuration for the Custom DNS demo.
#
# Edit these values before running any make targets.
# All scripts read from this file. No interactive prompts at runtime.
#
# After editing, run:
#   make demo            (Kind — local cluster)
#   make azure-demo      (Azure — cloud VMs)

# ── Shared ──────────────────────────────────────────────────────────

CLUSTER_NAME=custom-dns
DOMAIN=custom-dns.local
WORKER_COUNT=2

# ── Kind (local) ───────────────────────────────────────────────────

# Container runtime: "podman" or "docker"
CONTAINER_CLI=podman

# ── Monitoring Ports (local port-forwards) ─────────────────────────

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── Azure ──────────────────────────────────────────────────────────

RESOURCE_GROUP=${CLUSTER_NAME}-rg
LOCATION=eastus
VM_SIZE=Standard_D8s_v5

VNET_NAME=${CLUSTER_NAME}-vnet
VNET_CIDR=10.0.0.0/16
SUBNET_NAME=${CLUSTER_NAME}-subnet
SUBNET_CIDR=10.0.1.0/24
NSG_NAME=${CLUSTER_NAME}-nsg

SSH_KEY_PATH=${HOME}/.ssh/${CLUSTER_NAME}-demo
SSH_USER=azureuser
